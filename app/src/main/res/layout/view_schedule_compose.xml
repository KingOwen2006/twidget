<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/schedule_compose_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_compose_bg"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/schedule_compose_top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/schedule_compose_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cancel"
            android:padding="12dp"
            android:src="@drawable/ic_schedule_close" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/schedule_compose_drafts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:text="@string/schedule_drafts"
            android:textColor="@color/oneui_accent"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/schedule_compose_submit"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/schedule_compose_post_button"
            android:gravity="center"
            android:minWidth="88dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/schedule_compose_post"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/schedule_compose_divider" />

    <HorizontalScrollView
        android:id="@+id/schedule_compose_toolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <ImageButton
                android:id="@+id/schedule_compose_attach_media"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/schedule_add_local_media"
                android:padding="10dp"
                android:src="@drawable/ic_schedule_media" />

            <ImageButton
                android:id="@+id/schedule_compose_download_media"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/schedule_download_media"
                android:padding="10dp"
                android:src="@drawable/ic_schedule_download"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/schedule_compose_pick_time"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/schedule_when"
                android:padding="10dp"
                android:src="@drawable/ic_schedule_time" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/schedule_compose_time_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="2dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:textColor="@color/oneui_text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/schedule_compose_divider" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/schedule_compose_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:id="@+id/schedule_compose_avatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/avatar_twidget"
                    android:contentDescription="@string/account"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/schedule_compose_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:gravity="top|start"
                        android:hint="@string/schedule_compose_hint"
                        android:inputType="textCapSentences|textMultiLine"
                        android:maxLength="280"
                        android:minLines="3"
                        android:textColor="@color/oneui_text_primary"
                        android:textColorHint="@color/oneui_text_secondary"
                        android:textSize="20sp" />

                    <HorizontalScrollView
                        android:id="@+id/schedule_compose_media_strip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:scrollbars="none"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/schedule_compose_media_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingBottom="4dp" />
                    </HorizontalScrollView>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
