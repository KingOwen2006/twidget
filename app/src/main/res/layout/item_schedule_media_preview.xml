<?xml version="1.0" encoding="utf-8"?>
<dev.oneuiproject.oneui.widget.RoundedFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="220dp"
    android:layout_height="219dp"
    android:layout_marginEnd="10dp"
    android:background="@drawable/schedule_media_preview_bg"
    android:clipToOutline="true"
    android:elevation="10dp"
    android:outlineProvider="background"
    android:translationZ="2dp"
    app:roundedCorners="none">

    <ImageView
        android:id="@+id/schedule_media_preview_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/oneui_divider"
        android:contentDescription="@string/schedule_local_media"
        android:scaleType="centerCrop" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/schedule_media_preview_remove"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:layout_margin="7dp"
        android:background="@drawable/schedule_media_remove_bg"
        android:contentDescription="@string/schedule_remove_media"
        android:padding="8dp"
        app:srcCompat="@drawable/ic_oui_close"
        app:tint="@android:color/white" />

</dev.oneuiproject.oneui.widget.RoundedFrameLayout>
